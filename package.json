{
  "name": "www-project",
  "version": "0.1.0-phase0-5b",
  "private": true,
  "description": "WWW Project — What We Wonder／大家想知道 (Phase 0–5B through public freshness feed)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "scheduler:lifecycle": "node dist/lifecycle-scheduler.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.ts",
    "test:integration:local": "node scripts/test-pg-integration-local.mjs",
    "smoke:admin:local": "node scripts/smoke-admin-local.mjs",
    "smoke:public:local": "node scripts/smoke-public-local.mjs",
    "demo:public:local": "node scripts/demo-public-local.mjs",
    "test:watch": "vitest",
    "migrate": "node scripts/migrate.mjs",
    "migrate:check": "node scripts/migrate.mjs --check"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pg": "^8.15.2",
    "pg": "^8.16.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
